{
  "buildCommand": "pnpm --filter @workspace/flora-max-media run build",
  "outputDirectory": "artifacts/flora-max-media/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
